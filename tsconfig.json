{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "paths": {
      "#shared/*": ["./shared/*"],
      "~/*": ["./*"],
      "@/*": ["./*"]
    }
  },
  "include": [
    "server/**/*.ts",
    "components/**/*.vue",
    "composables/**/*.ts",
    "pages/**/*.vue",
    "shared/**/*.ts",
    "scripts/**/*.ts",
    "nuxt.config.ts",
    "app.vue"
  ]
}
